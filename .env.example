# Example environment configuration for wFirma API
# Copy this file to .env and fill in your credentials

# wFirma API Credentials
WFIRMA_APP_KEY=your_app_key_here
WFIRMA_SECRET=your_secret_here

# Environment (sandbox or production)
WFIRMA_ENVIRONMENT=sandbox

# HTTP Client Configuration
WFIRMA_TIMEOUT=30
WFIRMA_MAX_RETRIES=3

# Optional: Company ID (if you have access to multiple companies)
# WFIRMA_COMPANY_ID=

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# WFIRMA_LOG_LEVEL=INFO

# Optional: Cache settings (if using caching in future versions)
# WFIRMA_CACHE_ENABLED=false
# WFIRMA_CACHE_TTL=3600

