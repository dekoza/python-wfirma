# wFirma API configuration
# Copy this file to .env and fill in your credentials

# API credentials (required)
WFIRMA_APP_KEY=your_app_key_here
WFIRMA_APP_SECRET=your_app_secret_here

# Environment: sandbox or production (default: sandbox)
WFIRMA_ENVIRONMENT=sandbox

# Request timeout in seconds (default: 30)
WFIRMA_TIMEOUT=30

# Company ID (if you have access to multiple companies)
# WFIRMA_COMPANY_ID=

